[Unit]
Description=Remodelator FastAPI service
After=network.target

[Service]
Type=simple
User=remodelator
Group=remodelator
WorkingDirectory=/opt/remodelator/app
EnvironmentFile=/etc/remodelator/remo-api.env
ExecStart=/opt/remodelator/app/.venv/bin/uvicorn --app-dir /opt/remodelator/app/src remodelator.interfaces.api.main:app --host 127.0.0.1 --port 8010 --workers 1
Restart=always
RestartSec=3
TimeoutStopSec=30
KillSignal=SIGINT
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/remodelator /etc/remodelator

[Install]
WantedBy=multi-user.target
