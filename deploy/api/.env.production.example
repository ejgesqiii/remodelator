REMODELATOR_ENV=production
REMODELATOR_DATA_DIR=/opt/remodelator/data
REMODELATOR_DB_URL=sqlite:////opt/remodelator/data/remodelator.db
REMODELATOR_SESSION_SECRET=CHANGE_ME_LONG_RANDOM
REMODELATOR_SESSION_TTL_SECONDS=43200
REMODELATOR_PUBLIC_PROPOSAL_TTL_SECONDS=1800
REMODELATOR_ALLOW_LEGACY_USER_HEADER=false
REMODELATOR_ADMIN_API_KEY=CHANGE_ME_LONG_RANDOM
REMODELATOR_ADMIN_USER_EMAILS=you@example.com
REMODELATOR_CORS_ORIGINS=https://your-web.web.app,https://your-web.firebaseapp.com
REMODELATOR_API_RATE_LIMIT_ENABLED=true
REMODELATOR_API_RATE_LIMIT_WINDOW_SECONDS=60
REMODELATOR_API_RATE_LIMIT_PUBLIC_MAX=120
REMODELATOR_API_RATE_LIMIT_AUTHENTICATED_MAX=240
REMODELATOR_SQLITE_JOURNAL_MODE=WAL
REMODELATOR_SQLITE_SYNCHRONOUS=NORMAL
REMODELATOR_SQLITE_BUSY_TIMEOUT_MS=5000
REMODELATOR_OPERATION_LOCK_TIMEOUT_SECONDS=10
REMODELATOR_BILLING_PROVIDER=stripe
REMODELATOR_BILLING_ANNUAL_SUBSCRIPTION_AMOUNT=1200.00
REMODELATOR_BILLING_REALTIME_PRICING_AMOUNT=10.00
REMODELATOR_BILLING_CURRENCY=USD
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_VERSION=2026-01-28.clover
STRIPE_PAYMENT_RETURN_URL=https://your-web.web.app/billing?stripe_return=1
OPENROUTER_API_KEY=or_xxx
OPENROUTER_MODEL=google/gemini-2.5-flash
REMODELATOR_AUDIT_RETENTION_DAYS=365
